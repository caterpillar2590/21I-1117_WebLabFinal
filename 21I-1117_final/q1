function Spinner() {
  return (
    <div style={{ display:"flex", alignItems:"center", justifyContent:"center", padding:"3rem" }}>
      <div style={{ width:32, height:32, border:"3px solid var(--color-border-tertiary)", borderTop:"3px solid #534AB7", borderRadius:"50%", animation:"spin 0.8s linear infinite" }} />
      <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
    </div>
  );
}

function GlobalNotification() {
  const { notification } = useDashboard();
  if (!notification) return null;
  const colors = notification.type === "success"
    ? { bg:"#eaf3de", color:"#3b6d11", border:"#97c459" }
    : { bg:"#fcebeb", color:"#a32d2d", border:"#f09595" };
  return (
    <div style={{ position:"fixed", top:20, right:20, zIndex:9999, background:colors.bg, color:colors.color, border:`1px solid ${colors.border}`, borderRadius:10, padding:"12px 20px", fontSize:14, fontWeight:500, boxShadow:"0 4px 16px rgba(0,0,0,0.08)", maxWidth:340, animation:"slideIn 0.3s ease" }}>
      <style>{`@keyframes slideIn{from{transform:translateX(40px);opacity:0}to{transform:translateX(0);opacity:1}}`}</style>
      {notification.msg}
    </div>
  );
}

