function Badge({ status }) {
  const s = STATUS_COLORS[status] || {};
  return (
    <span style={{ background:s.bg, color:s.color, border:`1px solid ${s.border}`, borderRadius:6, padding:"2px 10px", fontSize:12, fontWeight:500, whiteSpace:"nowrap" }}>
      {status}
    </span>
  );
