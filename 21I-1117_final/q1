import { useState, useEffect, useContext, createContext, useCallback, useRef } from "react";

// ─── Global Context ───────────────────────────────────────────────────────────
const DashboardContext = createContext(null);

function generateChartData(timeRange) {
  const configs = {
    "12months": { labels: ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"], count: 12 },
    "30days":   { labels: Array.from({length:30},(_,i)=>`D${i+1}`), count: 30 },
    "7days":    { labels: ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"], count: 7 },
    "24hours":  { labels: Array.from({length:24},(_,i)=>`${i}h`), count: 24 },
  };
  const cfg = configs[timeRange] || configs["12months"];
  return {
    labels: cfg.labels,
    visitors: Array.from({length:cfg.count},()=>Math.floor(Math.random()*8000+2000)),
    pageviews: Array.from({length:cfg.count},()=>Math.floor(Math.random()*15000+5000)),
    activeUsers: Array.from({length:cfg.count},()=>Math.floor(Math.random()*3000+500)),
  };
}

function DashboardProvider({ children }) {
  const [timeRange, setTimeRange] = useState("12months");
  const [productsList, setProductsList] = useState([]);
  const [logisticsFilter, setLogisticsFilter] = useState("all");
  const [selectedProductId, setSelectedProductId] = useState(null);
  const [chartData, setChartData] = useState(() => generateChartData("12months"));
  const [notification, setNotification] = useState(null);

  const updateTimeRange = useCallback((range) => {
    setTimeRange(range);
    setChartData(generateChartData(range));
  }, []);

  const showNotification = useCallback((msg, type = "success") => {
    setNotification({ msg, type });
    setTimeout(() => setNotification(null), 3500);
  }, []);

  return (
    <DashboardContext.Provider value={{
      timeRange, updateTimeRange, chartData,
      productsList, setProductsList,
      logisticsFilter, setLogisticsFilter,
      selectedProductId, setSelectedProductId,
      notification, showNotification,
    }}>
      {children}
    </DashboardContext.Provider>
  );
}

const useDashboard = () => useContext(DashboardContext);

// ─── Router ───────────────────────────────────────────────────────────────────
function useRouter() {
  const [path, setPath] = useState(() => window.location.hash.slice(1) || "/");
  useEffect(() => {
    const handler = () => setPath(window.location.hash.slice(1) || "/");
    window.addEventListener("hashchange", handler);
    return () => window.removeEventListener("hashchange", handler);
  }, []);
  const navigate = (to) => { window.location.hash = to; };
  return { path, navigate };
}

