}

// ─── App Shell ────────────────────────────────────────────────────────────────
function AppShell() {
  const { path, navigate } = useRouter();

  const renderScreen = () => {
    if (path === "/" || path === "") return <AnalyticsScreen navigate={navigate} />;
    if (path === "/products") return <ProductsScreen navigate={navigate} />;
    if (path === "/add-product") return <AddProductScreen navigate={navigate} />;
    if (path === "/ecommerce") return <EcommerceScreen />;
    if (path === "/logistics") return <LogisticsScreen />;
    return <AnalyticsScreen navigate={navigate} />;
  };

  return (
    <div style={{ display:"flex", minHeight:"100vh", background:"var(--color-background-tertiary)", fontFamily:"var(--font-sans)" }}>
      <Sidebar path={path} navigate={navigate} />
      <main style={{ flex:1, overflowY:"auto", overflowX:"hidden" }}>
        {renderScreen()}
      </main>
      <GlobalNotification />
    </div>
  );
}

// ─── Root ─────────────────────────────────────────────────────────────────────
export default function App() {
  return (
    <DashboardProvider>
      <AppShell />
    </DashboardProvider>
  );
}
